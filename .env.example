# Shared server and worker secrets
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
MASTER_ENCRYPTION_KEY=

# Dashboard
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=https://payouts.example.com
DASHBOARD_PASSWORD_HASH=
SESSION_SECRET=

# Solana and external services
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
JUPITER_API_KEY=
HELIUS_API_KEY=
HELIUS_WEBHOOK_URL=https://payouts.example.com/webhooks/helius
HELIUS_WEBHOOK_AUTH=

# Optional security monitoring
# Enables VPN/proxy enrichment for dashboard-login and Supabase log-drain alerts.
IPINFO_TOKEN=
# Use a separate random secret. Configure a Supabase generic HTTP log drain to send:
# Authorization: Bearer YOUR_SECRET
# Endpoint: https://payouts.example.com/webhooks/supabase/logs
SUPABASE_LOG_DRAIN_AUTH=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_OWNERS_GUILD_ID=

# Leave true until the devnet checklist has passed.
DRY_RUN=true
RECONCILE_INTERVAL_MS=60000
EVENT_INTERVAL_MS=10000
PRIVACY_CASH_INTERVAL_MS=60000
ROTATION_CHECK_INTERVAL_MS=21600000
HELIUS_SYNC_INTERVAL_MS=600000

# Reverse proxy
DASHBOARD_DOMAIN=payouts.example.com
